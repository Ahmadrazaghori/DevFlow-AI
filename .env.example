# ============================================================
# Root-level environment file — used ONLY by docker-compose.yml
# for variable interpolation (${POSTGRES_PASSWORD} etc).
# This is DIFFERENT from backend/.env and frontend/.env, which
# are loaded inside the containers themselves.
#
# Copy this to `.env` (same folder as docker-compose.yml) and
# use the SAME values you put in backend/.env, so both are in sync.
# ============================================================

POSTGRES_USER=devflow
POSTGRES_PASSWORD=
POSTGRES_DB=devflow_ai

REDIS_PASSWORD=

VITE_API_BASE_URL=/api/v1
