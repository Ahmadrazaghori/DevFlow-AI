# ============================================================
# DevFlow AI — Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the actual `.env` file to version control.
# ============================================================

# --- Application ---
APP_NAME=DevFlow AI
APP_ENV=development            # development | staging | production
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=                    # generate: python -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# --- Database (PostgreSQL) ---
POSTGRES_USER=devflow
POSTGRES_PASSWORD=             # required, set a strong password
POSTGRES_DB=devflow_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis (cache, celery broker, rate limiting) ---
REDIS_PASSWORD=                # required, set a strong password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# --- Celery ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# --- JWT Authentication ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=devflow-ai

# --- Password Hashing (Argon2) ---
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute

# --- SMTP (Email Verification / Password Reset) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=                 # use an App Password, not your real Gmail password
SMTP_FROM_EMAIL=noreply@devflow-ai.com
SMTP_FROM_NAME=DevFlow AI
SMTP_USE_TLS=true

# --- Frontend URLs (used in email links) ---
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_URL=${FRONTEND_URL}/verify-email
PASSWORD_RESET_URL=${FRONTEND_URL}/reset-password

# --- AI Provider (Anthropic Claude) ---
ANTHROPIC_API_KEY=             # required for all AI features
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096

# --- Logging ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                # json | console
LOG_FILE_PATH=/app/logs/app.log
